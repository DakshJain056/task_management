# Database connection URL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/task_management

# Redis cache connection URL
REDIS_URL=redis://127.0.0.1:6379

# JSON Web Token signature secret (should be a secure, random string in production)
JWT_SECRET=super_secret_jwt_key_that_is_long_enough_to_be_secure_123456

# Log filtering level (tracing level for task_management and other libraries)
RUST_LOG=info
